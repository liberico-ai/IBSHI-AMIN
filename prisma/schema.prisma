// ===== M3 — Phiếu kê khai tổ trưởng + Đối soát + Giải trình =====

model Project {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  client    String?
  status    String   @default("ACTIVE")
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dailyReports DailyTeamReport[]
}

model WorkCode {
  id        String         @id @default(uuid())
  code      String         @unique
  name      String
  types     WorkTypeCode[]
  createdAt DateTime       @default(now())
}

model WorkTypeCode {
  id          String   @id @default(uuid())
  workCodeId  String
  workCode    WorkCode @relation(fields: [workCodeId], references: [id], onDelete: Cascade)
  code        String
  description String

  @@unique([workCodeId, code])
}

model DailyTeamReport {
  id          String    @id @default(uuid())
  date        DateTime
  teamId      String
  foremanId   String
  status      String    @default("DRAFT")
  submittedAt DateTime?
  approvedAt  DateTime?
  approvedBy  String?
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  entries DailyTeamEntry[]
  issues  DailyTeamIssue[]

  @@index([teamId, date])
}

model DailyTeamEntry {
  id              String          @id @default(uuid())
  reportId        String
  report          DailyTeamReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  employeeId      String
  projectCode     String?
  regularHours    Float           @default(0)
  isSundayWork    Boolean         @default(false)
  otHours         Float           @default(0)
  isReinforcement Boolean         @default(false)
  workCode        String?
  workTypeCode    String?
  description     String?
  isAbsent        Boolean         @default(false)
  note            String?

  @@index([reportId])
  @@index([employeeId])
}

model DailyTeamIssue {
  id            String          @id @default(uuid())
  reportId      String
  report        DailyTeamReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  type          String
  description   String
  affectedHours Float
  note          String?
}

model AttendanceCorrection {
  id            String    @id @default(uuid())
  employeeId    String
  date          DateTime
  errorType     String
  reason        String
  attachmentUrl String?
  status        String    @default("PENDING")
  approverId    String?
  approvedAt    DateTime?
  notes         String?
  createdAt     DateTime  @default(now())

  @@index([employeeId, date])
}

// ===== M4 — Onboarding + Offer Letter + Đánh giá thử việc =====

model OfferLetter {
  id                  String    @id @default(uuid())
  candidateId         String
  letterNumber        String    @unique // VD: "703/2026/TM-IBSHI" — auto sinh khi gửi
  position            String    // Vị trí làm việc (vd "Kỹ sư kỹ thuật") → Employee.jobPosition
  jobRole             String?   // Chức vụ (Nhân viên / Tổ trưởng / Trưởng phòng...) → Employee.jobRole
  departmentName      String?
  workLocation        String    @default("Km 6 Quốc lộ 5, Phường Hồng Bàng, Thành phố Hải Phòng, Việt Nam")
  officialSalary      Decimal   // Lương chính thức sau thử việc (= tổng các thành phần bên dưới)
  salaryBreakdown     Json?     // {baseSalary, farAllowance, kpiAllowance, positionAllowance} — chi tiết để dựng HĐ
  probationarySalary  Decimal   // Lương thử việc (= 85% lương chính thức)
  probationDays       Int       @default(60)
  startDate           DateTime
  probationEndDate    DateTime  // = startDate + probationDays
  benefits            String?
  body                String?   // Nội dung tự do (HR có thể chỉnh)
  status              String    @default("DRAFT") // DRAFT | PENDING_HR_MGR | APPROVED | REJECTED | SENT | ACCEPTED | DECLINED | EXPIRED
  // ── Workflow approval ──
  submittedAt         DateTime?
  approvedBy          String?   // FK Employee
  approvedAt          DateTime?
  rejectedBy          String?
  rejectedAt          DateTime?
  rejectComments      String?
  // ── Sending + tracking ──
  sentAt              DateTime?
  sentToEmail         String?
  pdfUrl              String?
  expiresAt           DateTime? // = sentAt + 7 days
  acceptedAt          DateTime?
  declinedAt          DateTime?
  candidateNote       String?
  // ── HĐ thử việc (soạn sau khi UV chấp nhận, TP HCNS duyệt trước khi onboard) ──
  probationDraft         Json?     // {startDate,endDate,baseSalary,jobRole,jobPosition,workLocation,terms,html}
  probationDraftStatus   String?   // null=chưa soạn | PENDING | APPROVED | REJECTED
  probationApprovedBy    String?
  probationApprovedAt    DateTime?
  probationRejectReason  String?
  // ── Audit ──
  createdBy           String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([status])
}

model OnboardingChecklist {
  id               String    @id @default(uuid())
  employeeId       String    @unique
  status           String    @default("IN_PROGRESS") // IN_PROGRESS | COMPLETED | EXTENDED
  startedAt        DateTime  @default(now())
  dueDate          DateTime?
  completedAt      DateTime?
  isExtended       Boolean   @default(false)
  extendedUntil    DateTime?
  extensionReason  String?
  extensionDocUrl  String?
  extensionGrantedAt DateTime?

  employee Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  items    ChecklistItem[]
}

model PositionRequirement {
  id          String   @id @default(uuid())
  positionId  String
  position    Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  name        String   // VD: "Chứng chỉ hàn AWS", "Bằng đại học", "GPLX hạng C"
  description String?
  isRequired  Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([positionId])
}

model ChecklistItem {
  id            String              @id @default(uuid())
  checklistId   String
  checklist     OnboardingChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  itemKey       String
  title         String
  isCompleted   Boolean             @default(false)
  completedAt   DateTime?
  attachmentUrl String?
  note          String?
  sortOrder     Int                 @default(0)

  @@unique([checklistId, itemKey])
}

model ProbationEvaluation {
  id                  String    @id @default(uuid())
  employeeId          String
  evaluatedBy         String
  evaluationDate      DateTime  @default(now())
  scores              Json      // { criteriaKey: "SATISFACTORY"|"NEEDS_IMPROVEMENT"|"UNACCEPTABLE"|"NA", q9YesNo: bool, q10YesNo: bool }
  totalScore          Float     // thang 10
  recommendedTier     String    // "INDEFINITE" | "DEFINITE_24M" | "DEFINITE_12M" | "FAIL"
  selectedTier        String?   // tier TP chốt (có thể override suggest)
  comments            String?
  status              String    @default("PENDING_DIRECTOR") // DRAFT | PENDING_DIRECTOR | APPROVED | CONTRACT_ISSUED | SIGNED | REJECTED | FAILED
  contractDraft       Json?     // nội dung HĐ soạn thảo: {contractNumber, contractType, startDate, endDate, baseSalary, allowance, kpi, jobTitle, workLocation, terms}
  contractIssuedAt    DateTime? // thời điểm phát hành HĐ (chuyển sang Đợi ký)
  directorApprovedBy  String?
  directorApprovedAt  DateTime?
  directorRejectedAt  DateTime?
  directorComments    String?
  hrSignedBy          String?
  hrSignedAt          DateTime?
  signedContractUrl   String?   // file scan HĐ NV đã ký
  signedContractId    String?   // FK tới Contract record được auto tạo
  contractStartDate   DateTime?
  contractEndDate     DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
}

// ===== M10 — 5 mảng mới =====

model MeetingRoom {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  capacity  Int
  location  String?
  equipment Json?    // string[] vd ["Wifi", "Tivi", "Máy chiếu", "Bảng trắng"]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  bookings RoomBooking[]
}

enum RoomBookingStatus {
  PENDING_APPROVAL  // Chờ duyệt (NV phụ trách phòng họp)
  APPROVED          // Đã duyệt — lock slot
  REJECTED
  CANCELLED         // NV tự huỷ
}

model RoomBooking {
  id              String            @id @default(uuid())
  roomId          String
  room            MeetingRoom       @relation(fields: [roomId], references: [id])
  requesterId     String            // employeeId của NV đặt
  requester       Employee          @relation("bookingRequester", fields: [requesterId], references: [id], onDelete: Restrict)
  startTime       DateTime
  endTime         DateTime
  title           String            // Tiêu đề cuộc họp
  description     String?           // Mô tả chi tiết
  priorityNote    String?           // Mức ưu tiên dạng text tự do (anh sontt yêu cầu)
  status          RoomBookingStatus @default(PENDING_APPROVAL)
  approvedById    String?
  approvedAt      DateTime?
  rejectReason    String?
  seriesId        String?           // Nếu là phần của series lặp lại — chung seriesId
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  attendees BookingAttendee[]

  @@index([roomId, startTime])
  @@index([requesterId])
  @@index([status])
  @@index([seriesId])
}

enum RsvpStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model BookingAttendee {
  id         String      @id @default(uuid())
  bookingId  String
  booking    RoomBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee    @relation("bookingAttendee", fields: [employeeId], references: [id], onDelete: Cascade)
  rsvp       RsvpStatus  @default(PENDING)
  respondedAt DateTime?

  @@unique([bookingId, employeeId])
  @@index([employeeId])
}

model RepairRequest {
  id             String    @id @default(uuid())
  requestedBy    String
  facilityType   String
  location       String
  description    String
  priority       String    @default("MEDIUM")
  attachmentUrls Json?
  status         String    @default("NEW")
  assignedTo     String?
  cost           Decimal?
  invoiceUrl     String?
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?

  @@index([status])
  @@index([priority])
}

model OfficeSupplyItem {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  unit      String
  unitPrice Decimal?
  category  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model PurchaseRequest {
  id           String    @id @default(uuid())
  prCode       String    @unique
  requestMonth String
  status       String    @default("DRAFT")
  totalAmount  Decimal?
  createdBy    String
  createdAt    DateTime  @default(now())
  approvedBy   String?
  approvedAt   DateTime?

  items    PurchaseRequestItem[]
  receipts StockReceipt[]
}

model PurchaseRequestItem {
  id        String          @id @default(uuid())
  prId      String
  pr        PurchaseRequest @relation(fields: [prId], references: [id], onDelete: Cascade)
  itemCode  String
  qty       Int
  unitPrice Decimal?
  note      String?

  @@index([prId])
}

model StockReceipt {
  id         String          @id @default(uuid())
  prId       String
  pr         PurchaseRequest @relation(fields: [prId], references: [id])
  receivedBy String
  receivedAt DateTime        @default(now())
  notes      String?
  invoiceUrl String?

  issuances Issuance[]
}

model Issuance {
  id           String       @id @default(uuid())
  receiptId    String
  receipt      StockReceipt @relation(fields: [receiptId], references: [id])
  issuedTo     String
  itemCode     String
  qty          Int
  issuedBy     String
  issuedAt     DateTime     @default(now())
  signatureUrl String?
}

model IncomingDocument {
  id          String    @id @default(uuid())
  docNumber   String?
  docDate     DateTime?
  recipientType String  @default("CONG_TY") // CONG_TY | CA_NHAN — gửi cho công ty hay đích danh cá nhân/phòng ban
  fromEntity  String?   // Đơn vị chuyển (khi gửi cho Công ty)
  subject     String?
  scanFileUrl String
  ocrJson     Json?
  routedTo    String?   // Tên hiển thị nơi nhận (NV/phòng ban) — khi recipientType = CA_NHAN
  routedEmployeeId   String? // Nơi nhận = 1 nhân viên cụ thể
  routedDepartmentId String? // Nơi nhận = 1 phòng ban
  status      String    @default("RECEIVED")
  receivedAt  DateTime  @default(now())
  processedAt DateTime?

  // Xác nhận đã nhận (chỉ với CA_NHAN) — phục vụ theo dõi lịch sử / thất lạc.
  confirmedAt    DateTime?
  confirmedById  String?
  confirmedByName String?

  @@index([status])
  @@index([routedTo])
}

model DocumentTemplate {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  htmlBody  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  documents OutgoingDocument[]
}

model OutgoingDocument {
  id         String            @id @default(uuid())
  docNumber  String            @unique
  docDate    DateTime          @default(now())
  templateId String?
  template   DocumentTemplate? @relation(fields: [templateId], references: [id])
  subject    String
  body       String
  toEntity   String?
  senderType String  @default("CONG_TY") // CONG_TY | CA_NHAN — người/đơn vị gửi
  senderName String?                      // Tên người gửi / đơn vị gửi (hiển thị)
  transportMethod String?       // Hình thức vận chuyển (Bưu điện / Chuyển phát nhanh / Trực tiếp...)
  transportUnit   String?       // Đơn vị vận chuyển (VNPost, Viettel Post, GHN...)
  signedBy   String?
  status     String            @default("DRAFT")
  pdfUrl     String?
  scanUrl    String?
  createdBy  String
  createdAt  DateTime          @default(now())

  @@index([status])
  @@index([docDate])
}

// ═══════════════════════════════════════════════════════════════════════════
// M10.3 — Văn phòng phẩm (Stationery)
// ═══════════════════════════════════════════════════════════════════════════

model StationerySupplier {
  id          String   @id @default(uuid())
  name        String   @unique           // "Super MRO", "BTcom"
  contactInfo String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  stockIns StationeryStockIn[]
}

// Catalog item — tên thống nhất (normalized) để tránh duplicate.
// Tồn kho hiện tại = tổng (StockInItem.quantity) − tổng (RequestItem.quantity của phiếu COMPLETED)
model StationeryItem {
  id             String @id @default(uuid())
  name           String                    // "Giấy A4", "Bút bi xanh", ...
  normalizedName String @unique            // lowercase + trim, dùng để fuzzy match
  unit           String                    // ĐVT: "ream", "cái", "hộp"
  note           String?                   // Ghi chú (vd "màu đen", "25x37")
  currentStock  Float   @default(0)       // cache tồn kho hiện tại
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  stockInItems  StationeryStockInItem[]
  requestItems  StationeryRequestItem[]

  @@index([normalizedName])
}

model StationeryStockIn {
  id          String   @id @default(uuid())
  supplierId  String
  importDate  DateTime                    // ngày nhập kho
  notes       String?
  createdById String                      // User HCNS staff
  createdAt   DateTime @default(now())

  supplier StationerySupplier      @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  items    StationeryStockInItem[]

  @@index([importDate])
  @@index([createdById])
}

model StationeryStockInItem {
  id        String @id @default(uuid())
  stockInId String
  itemId    String
  quantity  Float

  stockIn StationeryStockIn @relation(fields: [stockInId], references: [id], onDelete: Cascade)
  item    StationeryItem    @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([stockInId])
  @@index([itemId])
}

enum StationeryRequestStatus {
  PENDING_APPROVAL   // Chờ duyệt
  APPROVED           // Đã duyệt (chờ HCNS hoàn thành cấp)
  COMPLETED          // Đã cấp (đã trừ tồn kho)
  REJECTED           // Từ chối
}

model StationeryRequest {
  id                  String                  @id @default(uuid())
  requesterEmployeeId String                  // NV yêu cầu (lấy tên/phòng/chức từ Employee)
  reason              String                  // Lý do đề xuất
  fileUrl             String                  // File Đề nghị VPP đã ký (bắt buộc)
  status              StationeryRequestStatus @default(PENDING_APPROVAL)

  createdById   String   // HCNS staff tạo phiếu
  createdAt     DateTime @default(now())
  approvedById  String?  // TP HCNS duyệt
  approvedAt    DateTime?
  completedById String?  // HCNS staff bấm Hoàn thành (đã cấp + trừ tồn)
  completedAt   DateTime?
  rejectedReason String?

  requester Employee                @relation("stationeryRequester", fields: [requesterEmployeeId], references: [id], onDelete: Restrict)
  items     StationeryRequestItem[]

  @@index([status])
  @@index([createdById])
  @@index([requesterEmployeeId])
}

model StationeryRequestItem {
  id        String @id @default(uuid())
  requestId String
  itemId    String
  quantity  Float
  issuedQuantity Float @default(0)  // số đã cấp phát (cho phép cấp một phần khi hàng về thiếu)
  note      String?

  request StationeryRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  item    StationeryItem    @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([requestId])
  @@index([itemId])
}
