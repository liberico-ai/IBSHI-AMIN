# ─────────────────────────────────────────────────────────────────────────────
# IBS ONE Platform — Environment Variables
# Copy to .env (local) hoặc provision trên deploy host trước `docker compose up`.
# Postgres + MinIO được giả định chạy sẵn trên host (không nằm trong compose).
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database (PostgreSQL — external, chạy sẵn trên host) ────────────────────
# Trong container, dùng host.docker.internal để trỏ về Postgres trên host Linux
# (extra_hosts đã được map trong docker-compose.yml).
# Local dev (không docker): đổi host thành localhost.
DATABASE_URL=postgresql://ibs_admin:ibs_secret@host.docker.internal:5432/ibs_one

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Bắt buộc. Generate: `openssl rand -hex 32`
NEXTAUTH_SECRET=replace-with-openssl-rand-hex-32-min-32-chars
NEXTAUTH_URL=http://localhost:7131
# Bật khi chạy sau reverse proxy (nginx/cloudflare) để NextAuth tin header host
AUTH_TRUST_HOST=true

# ── MinIO (S3-compatible file storage — external, chạy sẵn trên host) ───────
MINIO_ENDPOINT=host.docker.internal
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

# ── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ── App Config ───────────────────────────────────────────────────────────────
APP_TIMEZONE=Asia/Ho_Chi_Minh

# ── Spec Section 12: Business Logic Configuration ────────────────────────────
# Pagination
PAGINATION_DEFAULT=20
PAGINATION_MAX=100

# Salary & OT rates
STANDARD_WORK_DAYS=26
OT_RATE_NORMAL=1.5
OT_RATE_WEEKEND=2.0
OT_RATE_HOLIDAY=3.0

# Insurance (Vietnam Social Insurance)
BHXH_SALARY_CAP=36000000
BHXH_RATE=0.08
BHYT_RATE=0.015
BHTN_RATE=0.01

# Personal income tax deductions
PERSONAL_DEDUCTION=11000000
DEPENDENT_DEDUCTION=4400000

# Allowances
MEAL_ALLOWANCE_PER_DAY=35000
HAZARD_ALLOWANCE=1200000
TEAM_LEAD_ALLOWANCE=800000
MANAGER_ALLOWANCE=1500000

# Leave quotas
ANNUAL_LEAVE_QUOTA=12

# Contract expiry warning window (days)
CONTRACT_EXPIRY_WARNING_DAYS=30
CERT_EXPIRY_WARNING_DAYS=30
