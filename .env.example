# Database
DATABASE_URL=postgresql://ibs_admin:ibs_secret@localhost:5432/ibs_one

# NextAuth
NEXTAUTH_SECRET=your-random-32-character-secret-here
NEXTAUTH_URL=http://localhost:3000

# MinIO (S3-compatible file storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# App Config
APP_TIMEZONE=Asia/Ho_Chi_Minh

# ── Spec Section 12: Business Logic Configuration ────────────────────────────
# Pagination
PAGINATION_DEFAULT=20
PAGINATION_MAX=100

# Salary & OT rates
STANDARD_WORK_DAYS=26
OT_RATE_NORMAL=1.5
OT_RATE_WEEKEND=2.0
OT_RATE_HOLIDAY=3.0

# Insurance (Vietnam Social Insurance)
BHXH_SALARY_CAP=36000000
BHXH_RATE=0.08
BHYT_RATE=0.015
BHTN_RATE=0.01

# Personal income tax deductions
PERSONAL_DEDUCTION=11000000
DEPENDENT_DEDUCTION=4400000

# Allowances
MEAL_ALLOWANCE_PER_DAY=35000
HAZARD_ALLOWANCE=1200000
TEAM_LEAD_ALLOWANCE=800000
MANAGER_ALLOWANCE=1500000

# Leave quotas
ANNUAL_LEAVE_QUOTA=12

# Contract expiry warning window (days)
CONTRACT_EXPIRY_WARNING_DAYS=30
CERT_EXPIRY_WARNING_DAYS=30
